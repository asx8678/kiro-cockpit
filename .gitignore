# OS/editor noise
.DS_Store
*.swp
*.swo
*~

# Python
.venv/
.pytest_cache/
__pycache__/
*.py[cod]
*$py.class

# Elixir/Phoenix build artifacts
/_build/
/deps/
/cover/
/.elixir_ls/
/.fetch
erl_crash.dump
*.ez
/priv/plts/*.plt
/priv/plts/*.plt.hash

# Phoenix assets/build artifacts
/node_modules/
/assets/node_modules/

# Generated static assets (digested, compressed, cache manifest)
# Keep source files like favicon.ico, robots.txt
# Keep .gitkeep to preserve empty assets directory
/priv/static/assets/*
!/priv/static/assets/.gitkeep
/priv/static/cache_manifest.json
/priv/static/*.gz
/priv/static/*-*.*
# Keep source files that shouldn't be digested
!/priv/static/favicon.ico
!/priv/static/robots.txt

# Environment and local config
.env
.env.*
!.env.example

# Beads / Dolt files (added by bd init)
.dolt/
*.db
*.db?*
.beads-credential-key
# ExUnit tmp_dir artifacts
tmp/
